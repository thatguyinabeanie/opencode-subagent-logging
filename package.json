{
  "name": "@opencode-ai/subagent-logging-plugin",
  "version": "1.0.0",
  "description": "OpenCode plugin for subagent logging and monitoring",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./src/*": {
      "import": "./src/*",
      "types": "./src/*"
    }
  },
  "scripts": {
    "dev": "bun run --watch index.ts",
    "build": "bun build index.ts --outdir=dist --target=node",
    "type-check": "bun tsc --noEmit",
    "lint": "bun run eslint src/**/*.ts subagent-logging.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^0.9.7",
    "@opencode-ai/sdk": "^0.9.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "bun-types": "^1.2.22"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "opencode",
    "plugin",
    "logging",
    "subagent",
    "monitoring"
  ],
  "license": "MIT"
}
