{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode/code-supernova",
  "small_model": "opencode/grok-code",

  // LSP Configuration for TypeScript development
  "lsp": {
    "typescript": {
      "command": ["bun", "x", "typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx"],
      "env": {},
    },
    "eslint": {
      "command": ["bun", "x", "vscode-langservers-extracted", "--stdio"],
      "extensions": [".ts", ".tsx", ".js"],
      "env": {},
    },
  },
}
