2025-09-19T01:38:25.950Z {"type":"message.part.updated","properties":{"part":{"id":"prt_95f9f5085001zf3YAkk4jU4XEr","messageID":"msg_95f9f478b0028wwCky374NC53o","sessionID":"ses_6a22f1392ffeQ0bXoNp2nAzh83","type":"tool","tool":"write","callID":"toolu_vrtx_01Pwtk96H5fRj6m4DSmhmh2Z","state":{"status":"running","input":{"content":"name: Check Conventional Commits\n\non:\n  pull_request:\n    types: [opened, synchronize, reopened, edited]\n\njobs:\n  commitlint:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n        with:\n          fetch-depth: 0\n\n      - name: Install mise\n        uses: jdx/mise-action@v2\n\n      - name: Install dependencies\n        run: bun install\n\n      - name: Validate commit messages\n        run: bunx commitlint --from ${{ github.event.pull_request.base.sha }} --to ${{ github.event.pull_request.head.sha }} --verbose\n\n  validate-pr-title:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Validate PR title\n        uses: amannn/action-semantic-pull-request@v5\n        env:\n          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n        with:\n          types: |\n            feat\n            fix\n            docs\n            style\n            refactor\n            test\n            chore\n            perf\n            ci\n            build\n            revert\n          requireScope: false\n          disallowScopes: |\n            release\n          subjectPattern: ^(?![A-Z]).+$\n          subjectPatternError: |\n            The subject \"{subject}\" found in the pull request title \"{title}\"\n            didn't match the configured pattern. Please ensure that the subject\n            doesn't start with an uppercase character.","filePath":"/Users/gmendoza/source/opencode/.opencode/plugin/.github/workflows/commitlint.yml"},"time":{"start":1758245905949}}}}}
