           echo \"@thatguyinabeanie:registry=https://npm.pkg.github.com\" >> ~/.npmrc\n00061|           echo \"//npm.pkg.github.com/:_authToken=${{ secrets.GITHUB_TOKEN }}\" >> ~/.npmrc\n00062| \n00063|       - name: Publish to GitHub Packages\n00064|         run: npm publish\n00065|         env:\n00066|           NODE_AUTH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n00067| \n</file>","metadata":{"preview":"name: CI\n\non:\n  push:\n    branches: [main, master]\n  pull_request:\n    branches: [main, master]\n\njobs:\n  ci:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Setup Bun\n        uses: oven-sh/setup-bun@v1\n        with:\n          bun-version: latest\n"},"title":"Users/gmendoza/source/opencode/.opencode/plugin/.github/workflows/ci.yml","time":{"start":1758245850883,"end":1758245850884}}}}}
